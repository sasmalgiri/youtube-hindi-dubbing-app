# ============================================
#  VoiceDub - API Keys Configuration
# ============================================
# Copy this file to .env and fill in your keys.
# Only add the keys for services you want to use.

# ── Translation APIs (pick at least one) ────
# OpenAI GPT-4o (best quality) - https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Google Gemini / Gemma 4 (free tier: 30 RPM per key) - https://aistudio.google.com/apikey
# Add multiple keys for faster parallel translation (each key = 30 RPM)
# GEMINI_API_KEY=AI...
# GEMINI_API_KEY_2=AI...
# GEMINI_API_KEY_3=AI...

# Groq Llama 3.3 70B (free, fast) - https://console.groq.com/keys
# GROQ_API_KEY=gsk_...

# Cerebras Llama 3.3 70B (FASTEST LLM, free 1M tokens/day) - https://cloud.cerebras.ai
# Add multiple keys for parallel translation
# CEREBRAS_API_KEY=csk-...
# CEREBRAS_API_KEY_2=csk-...

# ── TTS APIs (optional) ─────────────────────
# ElevenLabs (premium voices) - https://elevenlabs.io/settings/api
# ELEVENLABS_API_KEY=...

# Google Cloud TTS (1M chars/mo free per billing account)
# Single credential (simplest):
# GOOGLE_APPLICATION_CREDENTIALS=path/to/credentials.json
#
# Multiple billing accounts with auto-rotation (stacks free tiers).
# Pool picks any credential with remaining monthly quota; counter is persisted
# to backend/google_tts_usage.json so restarts don't lose state. Use any of:
#   (a) Directory of JSONs — easiest:
# GOOGLE_TTS_CREDENTIALS_DIR=backend/creds
#   (b) Comma-separated paths:
# GOOGLE_TTS_CREDENTIALS=backend/creds/proj1.json,backend/creds/proj2.json
#   (c) Numbered env vars:
# GOOGLE_TTS_CREDENTIAL_1=backend/creds/proj1.json
# GOOGLE_TTS_CREDENTIAL_2=backend/creds/proj2.json
# GOOGLE_TTS_CREDENTIAL_3=backend/creds/proj3.json
# GOOGLE_TTS_CREDENTIAL_4=backend/creds/proj4.json
# GOOGLE_TTS_CREDENTIAL_5=backend/creds/proj5.json
#
# Safety margin below the 1M free tier (default 950000 per credential):
# GOOGLE_TTS_QUOTA_PER_CREDENTIAL=950000

# ── Supabase Job Store (optional) ───────────
# Enables real-time job sync to Supabase (alongside local SQLite).
# Get URL + service_role key from: Supabase Dashboard → Settings → API
# SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Speaker Diarization (optional) ──────────
# HuggingFace token for pyannote speaker diarization
# Get from https://huggingface.co/settings/tokens
# Also accept terms at https://huggingface.co/pyannote/speaker-diarization-3.1
# HF_TOKEN=hf_...
